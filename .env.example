# ──────────────────────────────────────
# Firebase 설정 (Firebase Console → 프로젝트 설정 → 일반)
# ──────────────────────────────────────
EXPO_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
EXPO_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxx

# ──────────────────────────────────────
# Google OAuth 클라이언트 ID
# ──────────────────────────────────────
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your_web_client_id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_WEB_REDIRECT_URI=https://your-app.web.app
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your_ios_client_id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your_android_client_id.apps.googleusercontent.com

# ──────────────────────────────────────
# Gemini AI 추천 프록시 (Vercel Serverless Function)
# ──────────────────────────────────────
EXPO_PUBLIC_GEMINI_PROXY_URL=/api/gemini-recommendation
# EXPO_PUBLIC_GEMINI_MODEL=gemini-1.5-flash  # (선택) 기본값: gemini-1.5-flash
